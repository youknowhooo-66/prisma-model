// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RBAC relationships
  roles     Role[]   @relation("UserRoles")
}

model AuditLog {
  id          String      @id @default(uuid())
  entity      String
  entityId    String
  action      String      // Use String instead of Enum for SQLite
  oldData     String?     // Use String instead of Json for SQLite
  newData     String?
  performedBy String?
  createdAt   DateTime    @default(now())
}

// Removed enum AuditAction as it's not supported in SQLite with Prisma 5

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  users       User[]       @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id    String @id @default(uuid())
  name  String @unique
  roles Role[] @relation("RolePermissions")
}
