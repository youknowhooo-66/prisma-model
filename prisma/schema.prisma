generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?

  posts  Post[]
  carros Carro[]
  unhas  Unha[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String? @db.Text
  published Boolean @default(false)

  author   User @relation(fields: [authorId], references: [id])
  authorId Int
}

model Carro {
  id     Int    @id @default(autoincrement())
  nome   String
  modelo String
  preco  Int

  marca   Marcas @relation(fields: [marcaId], references: [id])
  marcaId Int

  dono   User @relation(fields: [userId], references: [id])
  userId Int

  @@map("carro")
}

model Unha {
  id      Int    @id @default(autoincrement())
  cor     String
  tamanho String
  preco   Int

  cliente   User @relation(fields: [userId], references: [id])
  userId    Int

  @@map("unha")
}

model Marcas {
  id              Int      @id @default(autoincrement())
  nome            String
  anoModelo       Int
  anoFabricacao   Int
  dataCadastro    DateTime @default(now())
  dataAtualizacao DateTime @updatedAt
  ativo           Boolean  @default(true)

  carros Carro[]

  @@map("marcas")
}